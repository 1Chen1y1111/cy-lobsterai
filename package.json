{
  "name": "cy-lobesterai",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build:skill:email": "cd SKILLs/imap-smtp-email && pnpm install --production",
    "build:skills": "pnpm run build:skill:email",
    "start:electron": "cross-env NODE_ENV=development ELECTRON_START_URL=http://localhost:5176 electron .",
    "electron:dev": "rimraf dist-electron && pnpm run compile:electron && concurrently \"vite --port 5176\" \"wait-on -v -t 120000 -d 10000 http://localhost:5176 && pnpm run start:electron\"",
    "compile:electron": "tsc --project electron-tsconfig.json"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/sql.js": "^1.4.9",
    "electron-log": "^5.4.3",
    "extract-zip": "^2.0.1",
    "js-yaml": "^4.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.16",
    "@types/extract-zip": "^2.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/uuid": "^11.0.0",
    "@types/yazl": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "40.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "tailwindcss": "3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^9.0.4"
  },
  "main": "dist-electron/main.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "bufferutil",
      "utf-8-validate"
    ]
  }
}
