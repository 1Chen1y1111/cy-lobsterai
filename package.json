    "@reduxjs/toolkit": "^2.11.2",
    "@types/sql.js": "^1.4.9",
    "@wecom/aibot-node-sdk": "^1.0.2",
    "axios": "^1.13.6",
    "cron-parser": "^5.5.0",
    "dingtalk-stream": "^2.1.5",
    "discord.js": "^14.25.1",
    "electron-log": "^5.4.3",
    "extract-zip": "^2.0.1",
    "form-data": "^4.0.5",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.38",
    "mermaid": "^11.13.0",
    "nim-web-sdk-ng": "10.9.77-alpha.4",
    "node-fetch": "^3.3.2",
    "protobufjs": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
